{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "bockylicious/curvy",
	"version": "0.1.0",
	"title": "Curvy",
	"category": "design",
	"icon": "smiley",
	"description": "Example block scaffolded with Create Block tool.",
	"example": {},
	"supports": {
		"html": false,
		"color": {
			"background": true,
			"text": true,
			"link": false
		},
		"spacing": {
			"padding": true,
			"__experimentalDefaultControls": {
				"padding": true
			}
		}
	},
	"attributes": {
		"style": {
			"type": "object",
			"default": {
				"color": {
					"background": "#ff0000",
					"text": "#000",
					"link": "#0ff"
				}
			}
		},
		"showTopCurvy": {
			"type": "boolean",
			"default": true
		},
		"topHorizontalFlip": {
			"type": "boolean",
			"default": false
		},
		"topVerticalFlip": {
			"type": "boolean",
			"default": false
		},
		"curvyWidth": {
			"type": "number",
			"default": 100
		},
		"curvyHeight": {
			"type": "number",
			"default": 100
		},
		"curvyColor": {
			"type": "string",
			"default": "#ffffff"
		}
	},
	"textdomain": "bockylicious",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"viewScript": "file:./view.js"
}
